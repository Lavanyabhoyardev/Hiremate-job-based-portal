# HireMate Backend — .gitignore

# Dependencies
node_modules/

# Environment files
.env
.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Uploads (runtime user data)
uploads/*
!uploads/.gitkeep

# Build outputs
dist/
build/

# Coverage
coverage/
.cache/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
